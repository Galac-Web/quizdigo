# =================================================
# 1. URL Rewrite Setup
# =================================================
RewriteEngine On

# Bypass pentru API
RewriteCond %{REQUEST_URI} ^/public/crududoc(?:\.php)?/?$ [OR]
RewriteCond %{REQUEST_URI} ^/crududoc(?:\.php)?/?$
RewriteRule ^ - [L]

# Front controller - Nu rescrie dacă există fișier/dir fizic
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# =================================================
# 2. MIME Types & Compresie
# =================================================
AddType application/font-woff2 .woff2
AddType application/font-woff  .woff
AddType application/x-font-ttf .ttf
AddType application/javascript .js
AddType text/javascript .js

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE font/woff font/woff2 font/ttf text/javascript application/javascript text/css text/html
</IfModule>

# =================================================
# 3. Securitate (Deblocare linkuri & CSP)
# =================================================
<IfModule mod_headers.c>
  # Curăță orice CSP setată în altă parte
  Header always unset Content-Security-Policy
  Header always unset Content-Security-Policy-Report-Only

  # =========================
  # CSP (SINGURĂ POLITICĂ)
  # =========================
Header always set Content-Security-Policy "default-src 'self'; \
base-uri 'self'; \
frame-ancestors 'self' https://meet.jit.si; \
script-src 'self' 'unsafe-inline' 'unsafe-eval' \
  https://accounts.google.com https://apis.google.com \
  https://cdn.tiny.cloud https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com \
  https://www.youtube.com https://www.youtube-nocookie.com; \
style-src 'self' 'unsafe-inline' \
  https://fonts.googleapis.com https://unpkg.com \
  https://cdn.tiny.cloud https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; \
img-src 'self' data: blob: \
  https://cdn.tiny.cloud https://images.unsplash.com https://via.placeholder.com \
  https://tile.openstreetmap.org https://*.tile.openstreetmap.org \
  https://i.ytimg.com https://img.youtube.com; \
media-src 'self' data: blob: https:; \
font-src 'self' data: \
  https://fonts.gstatic.com https://fonts.googleapis.com \
  https://unpkg.com https://cdn.tiny.cloud https://cdnjs.cloudflare.com; \
connect-src 'self' \
  https://accounts.google.com https://oauth2.googleapis.com https://www.googleapis.com \
  https://cdn.tiny.cloud \
  https://tile.openstreetmap.org https://*.tile.openstreetmap.org \
  https://www.youtube.com https://www.youtube-nocookie.com; \
frame-src 'self' \
  https://www.youtube.com https://www.youtube-nocookie.com; \
child-src 'self' \
  https://www.youtube.com https://www.youtube-nocookie.com; \
form-action 'self'"

  # Headers securitate
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # CORS (atenție: '*' e OK doar dacă chiar ai nevoie public API)
  Header set Access-Control-Allow-Origin "*"
  Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
  Header set Access-Control-Allow-Headers "Content-Type, Authorization"
</IfModule>

# =================================================
# 4. PHP Settings (Varianta Safe)
# =================================================
# Dacă eroarea 500 persistă, comentează liniile de mai jos cu #
<IfModule mod_php7.c>
    php_flag display_errors on
    php_flag log_errors on
</IfModule>
<IfModule mod_php.c>
    php_flag display_errors on
    php_flag log_errors on
</IfModule>

# =================================================
# 5. Protecție Fișiere & Directoare
# =================================================
Options -Indexes

<Files .htaccess>
  Order allow,deny
  Deny from all
</Files>

<FilesMatch "\.(env|ini|log|sh|bak|sql)$">
  Order allow,deny
  Deny from all
</FilesMatch>